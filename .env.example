# =============================================================================
# yog-sothoth — Workspace configuration
# =============================================================================
# Copy this file to .env at the workspace root and fill in the values.
# .env is git-ignored — never commit real credentials.
#
# A single .env file at the workspace root is loaded by every binary in the
# workspace (indexer, api, context, migrate) via `dotenvy::dotenv()`. Each
# process reads only the variables it cares about — see "Database" below.
#
# The same .env file is read automatically by `docker compose` for variable
# interpolation in docker-compose.yml. One file for both local `cargo run`
# and the dockerised stack.
# =============================================================================


# -----------------------------------------------------------------------------
# Database — split roles for least privilege
# -----------------------------------------------------------------------------
# Four Postgres roles back the application:
#
#   yog_migrate : DDL only — owns the schema, applies migrations.
#                 Used by the one-shot yog-migrate binary, never by a
#                 running service.
#
#   yog_indexer : RW on event tables (pools, swap_events, liquidity_events,
#                 position_fee_claims, reward_claims, pool_current_state,
#                 network_status), RO on watched_pools.
#                 Used by the indexer process at runtime.
#
#   yog_api     : RO on event tables, watched_pools, token_metadata,
#                 token_prices.
#                 Used by the api process at runtime.
#                 v0.3 will extend it with RW on user-facing tables
#                 (users, alert_subscriptions, …).
#
#   yog_context : RW on token_metadata and token_prices, RO on pools.
#                 Used by the context process at runtime.
#
#   admin       : full superuser — used by `cargo sqlx prepare` to
#                 compile-check queries across the whole workspace, and
#                 to bootstrap the database (apply setup_roles.sql).
#                 NEVER used by a running service.
#
# The four service roles and their grants are created once per database via
# `crates/persistence/setup_roles.sql`, applied as admin.
#
# Format : postgresql://<user>:<password>@<host>:<port>/<database>
#
# Local development : host = localhost, port = 5433 (the Docker port mapping
#   on the timescaledb container; avoids conflicting with a host PostgreSQL).
#
# Inside the docker compose network : host = postgres, port = 5432 (the
#   container's internal port). docker-compose.yml rewrites these URLs to
#   use the internal hostname when running the dockerised services.
#
# Production (Scaleway Managed PostgreSQL) : provide each connection string
# as an environment variable on the corresponding container — do not ship
# this file to production.

# Read by the yog-migrate binary (crates/persistence/src/bin/migrate.rs).
DATABASE_URL_MIGRATE=postgresql://yog_migrate:CHANGE_ME@localhost:5433/yog_sothoth

# Read by the indexer process (crates/indexer/src/main.rs).
DATABASE_URL_INDEXER=postgresql://yog_indexer:CHANGE_ME@localhost:5433/yog_sothoth

# Read by the api process (crates/api/src/main.rs).
DATABASE_URL_API=postgresql://yog_api:CHANGE_ME@localhost:5433/yog_sothoth

# Read by the context process (crates/context/src/main.rs).
DATABASE_URL_CONTEXT=postgresql://yog_context:CHANGE_ME@localhost:5433/yog_sothoth

# Used by tooling only — `cargo sqlx prepare --workspace` and to apply
# setup_roles.sql when bootstrapping a new database. Not read by any
# running service.
DATABASE_URL_ADMIN=postgresql://yog:yog@localhost:5433/yog_sothoth
DATABASE_URL=postgresql://yog:yog@localhost:5433/yog_sothoth

# Whether sqlx should run in offline mode (against the cached `.sqlx/`
# directory) instead of querying the live database at compile time.
# Keep `true` for normal builds; set to `false` (or unset) only when
# regenerating the cache via `cargo sqlx prepare`.
SQLX_OFFLINE=true


# -----------------------------------------------------------------------------
# Postgres container — used by docker compose
# -----------------------------------------------------------------------------
# Only consumed by docker-compose.yml to provision the `postgres` service
# (the timescaledb image's POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB).
# These are the credentials of the ADMIN user inside the container, NOT of
# any application role.
#
# Application binaries do not read these variables — they read the four
# DATABASE_URL_* above.
POSTGRES_USER=yog
POSTGRES_PASSWORD=yog
POSTGRES_DB=yog_sothoth


# -----------------------------------------------------------------------------
# API server — bind address
# -----------------------------------------------------------------------------
# Where the api process listens for incoming TCP connections.
# Format : <host>:<port>  (passed as-is to `TcpListener::bind`).
#
# This is NOT a public URL. There is no `http://` or `https://` here — the
# scheme and TLS termination are handled by the reverse proxy (Caddy on
# Scaleway), not by the api process itself.
#
# Local development (cargo run) : 127.0.0.1:5000
#   Listens on the loopback interface only. Reachable from Next.js running
#   on the same machine, but not from other devices on the LAN.
#
# Docker : 0.0.0.0:5000
#   Required when running inside a container so the reverse proxy on the
#   host can route traffic to it. docker-compose.yml overrides this
#   variable to 0.0.0.0:5000 for the yog-api service automatically.
#
# Next.js (the dashboard) reaches the api via this address in dev. In
# production it goes through https://api.yog-sothoth.fr → Caddy → this port.
# Next.js's own configuration (NEXT_PUBLIC_API_URL) lives in the Next.js
# project's `.env.local`, not here.
API_BIND_ADDR=127.0.0.1:5000


# -----------------------------------------------------------------------------
# Solana RPC — WebSocket
# -----------------------------------------------------------------------------
# Used by the indexer to subscribe to transaction logs in real time.
#
# Free public endpoint (development only — rate-limited, no SLA) :
#   wss://api.mainnet-beta.solana.com
#
# Production : switch to a dedicated RPC provider (Helius, QuickNode, Triton…)
# to avoid rate limiting and ensure uptime.
#   wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com


# -----------------------------------------------------------------------------
# Solana RPC — HTTP
# -----------------------------------------------------------------------------
# Used by IndexerService to fetch full transaction data by signature, and
# by yog-context for the Helius DAS calls (getAssetBatch).
#
# Free public endpoint (development only) :
#   https://api.mainnet-beta.solana.com
#
# Production example :
#   https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
SOLANA_RPC_HTTP=https://api.mainnet-beta.solana.com


# -----------------------------------------------------------------------------
# Jupiter Price API V3 — used by yog-context
# -----------------------------------------------------------------------------
# Endpoint and authentication for the price worker. Base URL is the Price
# API V3 (https://api.jup.ag); the key is sent on every request
# via the `x-api-key` header. Get a key at https://portal.jup.ag/.
JUPITER_URL=https://api.jup.ag
JUPITER_API_KEY=CHANGE_ME


# -----------------------------------------------------------------------------
# yog-context — daemon intervals
# -----------------------------------------------------------------------------
# How often the metadata worker polls `pools` for mints not yet enriched
# (and fetches them from Helius DAS).
CONTEXT_METADATA_POLL_SECS=10

# How often the price worker fetches USD prices for every known mint
# from Jupiter.
CONTEXT_PRICE_INTERVAL_SECS=30


# -----------------------------------------------------------------------------
# Indexer behavior
# -----------------------------------------------------------------------------
# Maximum number of consecutive retries a SubscriptionWorker performs
# before giving up. The counter resets after a successful subscription,
# so this bounds connection failures, not long-running churn.
#
# Required (no implicit default — the value must be explicit in your env).
RPC_WORKER_MAX_RETRIES=10

# Indexing mode :
#   true  → protocol-centric : subscribe to programs, discover pools in the flow
#   false → pool-centric     : subscribe only to pools explicitly watched
#
# Pool-centric is a transitional fallback used while the public RPC cannot
# sustain the full protocol firehose. Protocol-centric is the target mode
# once a paid RPC (Helius / Shyft / Triton) is in place.
MODE_PROTOCOL_CENTRIC=true


# -----------------------------------------------------------------------------
# Log level
# -----------------------------------------------------------------------------
# Controls the verbosity of the tracing subscriber.
# Syntax : <target>=<level> — multiple directives separated by commas.
#
# Examples :
#   debug                             → everything at debug and above
#   info                              → recommended for production
#   yog_indexer=debug,warn            → debug for this crate, warn for others
#
# Levels (lowest → highest) : trace | debug | info | warn | error
RUST_LOG=info,sqlx=warn

# -----------------------------------------------------------------------------
# Log format
# -----------------------------------------------------------------------------
# Controls the output format of the tracing subscriber.
#
#   json → structured JSON — recommended for production (Loki, Datadog, etc.)
#   text → human-readable — recommended for local development
#
# If unset, defaults to text.
LOG_FORMAT=text


# -----------------------------------------------------------------------------
# Web (Next.js) — only consumed by docker compose with profile=full
# -----------------------------------------------------------------------------
# Public URL the browser will use to reach the app. Used by Next.js to
# generate absolute links (Open Graph tags, emails, etc.).
NEXT_PUBLIC_APP_URL=http://localhost:3000
