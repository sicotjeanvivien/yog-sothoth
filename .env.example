# =============================================================================
# yog-sothoth — Workspace configuration
# =============================================================================
# Copy this file to .env at the workspace root and fill in the values.
# .env is git-ignored — never commit real credentials.
#
# A single .env file at the workspace root is loaded by every binary in the
# workspace (indexer, api, …) via `dotenvy::dotenv()`. Each process reads
# only the variables it cares about — see "Database" below.
# =============================================================================


# -----------------------------------------------------------------------------
# Database — split roles for least privilege
# -----------------------------------------------------------------------------
# Three Postgres roles back the application:
#
#   yog_indexer : RW on event tables (pools, swap_events, liquidity_events,
#                 position_fee_claims, reward_claims), RO on watched_pools.
#                 Used by the indexer process at runtime.
#
#   yog_api     : RO on event tables and watched_pools.
#                 Used by the api process at runtime.
#                 v0.3 will extend it with RW on user-facing tables
#                 (users, alert_subscriptions, …).
#
#   admin       : full DDL — owns the schema, runs migrations, and is the
#                 role used by `cargo sqlx prepare` to compile-check queries
#                 across the whole workspace.
#                 NEVER used by a running service.
#
# The roles and their grants are created once per database via
# `crates/persistence/setup_roles.sql`.
#
# Format : postgresql://<user>:<password>@<host>:<port>/<database>
# Default port for the local Docker container : 5433
# (avoids conflict with a local PostgreSQL instance on 5432)
#
# Production (Scaleway Managed PostgreSQL) : provide each connection string
# as an environment variable on the corresponding container — do not ship
# this file to production.

# Read by the indexer process (crates/indexer/src/main.rs).
DATABASE_URL_INDEXER=postgresql://yog_indexer:CHANGE_ME@localhost:5433/yog_sothoth

# Read by the api process (crates/api/src/main.rs).
DATABASE_URL_API=postgresql://yog_api:CHANGE_ME@localhost:5433/yog_sothoth

# Used by tooling only — `sqlx migrate run`, `cargo sqlx prepare --workspace`.
# Not read by any running service.
DATABASE_URL_ADMIN=postgresql://postgres:CHANGE_ME@localhost:5433/yog_sothoth

# Whether sqlx should run in offline mode (against the cached `.sqlx/`
# directory) instead of querying the live database at compile time.
# Keep `true` for normal builds; set to `false` (or unset) only when
# regenerating the cache via `cargo sqlx prepare`.
SQLX_OFFLINE=true


# -----------------------------------------------------------------------------
# API server — bind address
# -----------------------------------------------------------------------------
# Where the api process listens for incoming TCP connections.
# Format : <host>:<port>  (passed as-is to `TcpListener::bind`).
#
# This is NOT a public URL. There is no `http://` or `https://` here — the
# scheme and TLS termination are handled by the reverse proxy (Caddy on
# Scaleway), not by the api process itself.
#
# Local development : 127.0.0.1:3000
#   Listens on the loopback interface only. Reachable from Next.js running
#   on the same machine, but not from other devices on the LAN.
#
# Docker / production : 0.0.0.0:3000
#   Listens on all interfaces. Required when running inside a container so
#   the reverse proxy on the host can route traffic to it.
#
# Next.js (the dashboard) reaches the api via this address in dev. In
# production it goes through https://api.yog-sothoth.fr → Caddy → this port.
# Next.js's own configuration (NEXT_PUBLIC_API_URL) lives in the Next.js
# project's `.env.local`, not here.
API_BIND_ADDR=127.0.0.1:5000


# -----------------------------------------------------------------------------
# Solana RPC — WebSocket
# -----------------------------------------------------------------------------
# Used by the indexer to subscribe to transaction logs in real time.
#
# Free public endpoint (development only — rate-limited, no SLA) :
#   wss://api.mainnet-beta.solana.com
#
# Production : switch to a dedicated RPC provider (Helius, QuickNode, Triton…)
# to avoid rate limiting and ensure uptime.
#   wss://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
SOLANA_RPC_WS=wss://api.mainnet-beta.solana.com


# -----------------------------------------------------------------------------
# Solana RPC — HTTP
# -----------------------------------------------------------------------------
# Used by IndexerService to fetch full transaction data by signature.
# Should point to the same provider as SOLANA_RPC_WS.
#
# Free public endpoint (development only) :
#   https://api.mainnet-beta.solana.com
#
# Production example :
#   https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
SOLANA_RPC_HTTP=https://api.mainnet-beta.solana.com


# -----------------------------------------------------------------------------
# Indexer behavior
# -----------------------------------------------------------------------------
# Maximum number of consecutive retries a SubscriptionWorker performs
# before giving up. The counter resets after a successful subscription,
# so this bounds connection failures, not long-running churn.
#
# Required (no implicit default — the value must be explicit in your env).
RPC_WORKER_MAX_RETRIES=10

# Indexing mode :
#   true  → protocol-centric : subscribe to programs, discover pools in the flow
#   false → pool-centric     : subscribe only to pools explicitly watched
#
# Pool-centric is a transitional fallback used while the public RPC cannot
# sustain the full protocol firehose. Protocol-centric is the target mode
# once a paid RPC (Helius / Shyft / Triton) is in place.
MODE_PROTOCOL_CENTRIC=true


# -----------------------------------------------------------------------------
# Log level
# -----------------------------------------------------------------------------
# Controls the verbosity of the tracing subscriber.
# Syntax : <target>=<level> — multiple directives separated by commas.
#
# Examples :
#   debug                             → everything at debug and above
#   info                              → recommended for production
#   yog_indexer=debug,warn            → debug for this crate, warn for others
#
# Levels (lowest → highest) : trace | debug | info | warn | error
RUST_LOG=yog_indexer=debug,yog_api=debug,yog_core=debug,yog_persistence=debug,sqlx=warn


# -----------------------------------------------------------------------------
# Log format
# -----------------------------------------------------------------------------
# Controls the output format of the tracing subscriber.
#
#   json → structured JSON — recommended for production (Loki, Datadog, etc.)
#   text → human-readable — recommended for local development
#
# If unset, defaults to text.
LOG_FORMAT=text
