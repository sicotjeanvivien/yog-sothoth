{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT pool_address, protocol, token_a_mint, token_b_mint,\n                       first_seen_at, last_seen_at\n                FROM pools\n                WHERE $1::TIMESTAMPTZ IS NULL\n                   OR first_seen_at > $1\n                   OR (first_seen_at = $1 AND pool_address < $2)\n                ORDER BY first_seen_at ASC, pool_address DESC\n                LIMIT $3\n                ",
