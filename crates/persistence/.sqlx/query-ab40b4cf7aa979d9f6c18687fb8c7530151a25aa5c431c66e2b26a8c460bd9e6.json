{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT id, detector, protocol, pool_address,\n                       severity, value, threshold, message,\n                       triggered_at\n                FROM signals\n                WHERE ($1::TEXT IS NULL OR severity = $1)\n                  AND (\n                      $2::TIMESTAMPTZ IS NULL\n                      OR triggered_at < $2\n                      OR (triggered_at = $2 AND id < $3)\n                  )\n                ORDER BY triggered_at DESC, id DESC\n                LIMIT $4\n                ",
