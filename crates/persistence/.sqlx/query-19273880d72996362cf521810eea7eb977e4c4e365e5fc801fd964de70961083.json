{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, kind, severity, message, link_url, starts_at, ends_at\n            FROM announcements\n            WHERE starts_at <= $1\n              AND (ends_at IS NULL OR ends_at > $1)\n            ORDER BY\n                CASE severity\n                    WHEN 'critical' THEN 0\n                    WHEN 'warning'  THEN 1\n                    ELSE 2\n                END,\n                starts_at DESC\n            LIMIT $2\n            ",
