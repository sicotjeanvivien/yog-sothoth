{
  "db_name": "PostgreSQL",
  "query": "\n            SELECT id, detector, protocol, pool_address,\n                   severity, value, threshold, message,\n                   triggered_at\n            FROM signals\n            WHERE triggered_at > $1\n               OR (triggered_at = $1 AND id > $2)\n            ORDER BY triggered_at ASC, id ASC\n            LIMIT $3\n            ",
