  "db_name": "PostgreSQL",
  "query": "\n            SELECT\n                bucket                AS \"bucket!\",\n                volume_usd,\n                fees_usd,\n                protocol_fees_usd,\n                swap_count,\n                liquidity_added_usd,\n                liquidity_removed_usd,\n                fees_claimed_usd,\n                rewards_claimed_usd\n            FROM meteora_damm_v2_pool_hourly_activity\n            WHERE pool_address = $1\n              AND bucket > NOW() - make_interval(days => $2)\n            ORDER BY bucket\n            ",
