  "query": "\n            SELECT pool_address, protocol, signature,\n                   position, owner,\n                   fee_a_claimed, fee_b_claimed,\n                   timestamp\n            FROM position_fee_claims\n            WHERE pool_address = $1\n            ORDER BY timestamp DESC\n            LIMIT $2\n            ",
