  "query": "\n            SELECT pool_address, protocol, signature,\n                   position, owner,\n                   mint_reward, reward_index, total_reward,\n                   timestamp\n            FROM reward_claims\n            WHERE pool_address = $1\n            ORDER BY timestamp DESC\n            LIMIT $2\n            ",
