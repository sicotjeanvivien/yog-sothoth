# --------------------------------------------------------------------
# Server-only configuration — NEVER prefix these with NEXT_PUBLIC_.
# They are read at boot by `src/lib/config/server-env.ts` and validated
# with zod; a missing or malformed value prevents the server from
# starting (fail-fast, mirrors `ConfigError::InvalidValue` in yog-api).
# --------------------------------------------------------------------

# Base URL of the yog-api Rust service. The Next.js server (BFF route
# handlers and Server Components) calls this URL; it never reaches the
# browser. Must NOT end with a trailing slash.
YOG_API_INTERNAL_URL=http://127.0.0.1:3001

# Timeout in milliseconds for BFF → yog-api calls. Defaults to 5000 if
# unset. The browser-facing request has its own (longer) Next.js
# default timeout; this one bounds the inner hop only.
# YOG_API_TIMEOUT_MS=5000

# --------------------------------------------------------------------
# Feature flags — every NEXT_PUBLIC_FEATURE_* flag is exposed to the
# browser bundle. Only the literal value `true` enables a flag; any
# other value (including `1`, `yes`, `True`) keeps it disabled.
#
# Source of truth: web/src/config/features.ts
#
# Status legend:
#   v0.1-on   = data available today, widget can ship
#   v0.1-deg  = available but rendered in a degraded path (polling)
#   pending-* = waiting on aggregate / signal engine / design / visual
# --------------------------------------------------------------------

# ---- v0.1-on (defaults to true; uncomment only to flip them off) ----
# NEXT_PUBLIC_FEATURE_POOLS_LIST=true
# NEXT_PUBLIC_FEATURE_POOL_DETAIL=true
# NEXT_PUBLIC_FEATURE_POOL_PRICE_IMBALANCE=true

# ---- v0.1-deg (defaults to true) ----
# NEXT_PUBLIC_FEATURE_TRANSACTION_FEED=true

# ---- pending-aggregate (defaults to false) ----
# NEXT_PUBLIC_FEATURE_TVL_TOTAL=false
# NEXT_PUBLIC_FEATURE_VOLUME_24H=false
# NEXT_PUBLIC_FEATURE_FEES_24H=false
# NEXT_PUBLIC_FEATURE_TVL_CHART=false
# NEXT_PUBLIC_FEATURE_PAIR_BREAKDOWN=false
# NEXT_PUBLIC_FEATURE_KEY_METRICS=false

# ---- pending-visual (defaults to false) ----
# NEXT_PUBLIC_FEATURE_LIQUIDITY_MAP=false
# NEXT_PUBLIC_FEATURE_LIQUIDITY_HEATMAP=false
# NEXT_PUBLIC_FEATURE_LIVE_STATUS_BAR=false

# ---- pending-design / pending-signals (defaults to false) ----
# NEXT_PUBLIC_FEATURE_LIQUIDITY_HEALTH_SCORE=false
# NEXT_PUBLIC_FEATURE_ALERTS_PANEL=false
# NEXT_PUBLIC_FEATURE_SIGNALS_FEED=false
