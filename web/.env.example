# --------------------------------------------------------------------
# Yog-Sothoth web — environment variables (template)
# Copy to `.env.local` and fill in the real values.
# --------------------------------------------------------------------

# Database connection — read-only user provisioned in Milestone 0.2.
# Format: postgresql://USER:PASS@HOST:PORT/DBNAME?sslmode=require
# DATABASE_URL=postgresql://yog_web:CHANGE_ME@localhost:5432/yog_sothoth?sslmode=disable

# --------------------------------------------------------------------
# Feature flags — every NEXT_PUBLIC_FEATURE_* flag is exposed to the
# browser bundle. Default state is `off`; only the widgets actually
# fed by the v0.1 indexer should be flipped to `true` for now.
# Each flag is documented in `src/config/features.ts` (Milestone 1.1).
# --------------------------------------------------------------------
# NEXT_PUBLIC_FEATURE_POOLS_LIST=true
# NEXT_PUBLIC_FEATURE_POOL_DETAIL=true
# NEXT_PUBLIC_FEATURE_TVL_TOTAL=false
# NEXT_PUBLIC_FEATURE_VOLUME_24H=false
# NEXT_PUBLIC_FEATURE_LIQUIDITY_HEALTH=false
# NEXT_PUBLIC_FEATURE_HEATMAP=false
# NEXT_PUBLIC_FEATURE_ALERTS=false
